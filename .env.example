# --- Discord ---
DISCORD_TOKEN=your-bot-token-here
COMMAND_PREFIX=!
# Comma-separated role names that grant cross-channel search + AI rule management
OWNER_ROLE_NAMES=Owner,Founder

# --- Database ---
DATABASE_URL=postgresql+asyncpg://bot_user:bot_password@localhost:5432/discord_ai_bot
DB_ECHO=false

# --- AI Providers ---
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

AI_SYSTEM_PROMPT=You are a helpful, concise Discord community AI assistant.

# --- Moderation ---
MAX_TIMEOUT_MINUTES=60

# --- Logging ---
LOG_LEVEL=INFO
# Display timezone for log timestamps and Discord embeds.
# The database ALWAYS stores UTC internally; this only changes how times are shown.
# Examples: 0=UTC, 2=UTC+2 (Central Africa/Eastern Europe), -5=UTC-5 (EST)
TZ_OFFSET_HOURS=2
# Optional: a Discord channel ID for forwarding important log events
LOG_CHANNEL_ID=
# Optional: a Discord channel ID staff escalations get posted to
ESCALATION_CHANNEL_ID=

# --- Phase 2/3: AI Constitution & confidence ---
CONFIDENCE_ESCALATION_THRESHOLD=0.55
AUTO_ACTION_CONFIDENCE_THRESHOLD=0.75
DUAL_REVIEW_ENABLED=true

# --- Phase 2/3: model routing (seed list; live config lives in ai_model_configs table) ---
OPENROUTER_CANDIDATE_MODELS=meta-llama/llama-3.1-8b-instruct:free,google/gemma-2-9b-it:free,mistralai/mistral-7b-instruct:free
GEMINI_CANDIDATE_MODELS=gemini-1.5-flash,gemini-1.5-flash-8b
MODEL_UNHEALTHY_AFTER_FAILURES=3
MODEL_HEALTH_COOLDOWN_SECONDS=300

# --- Phase 2/3: memory ---
SHORT_TERM_MEMORY_TTL_SECONDS=1800

# --- Phase 2/3: heuristic detectors ---
SPAM_MESSAGE_THRESHOLD=6
SPAM_WINDOW_SECONDS=10
RAID_JOIN_THRESHOLD=8
RAID_WINDOW_SECONDS=30
REPEAT_OFFENDER_WARNING_COUNT=3
REPEAT_OFFENDER_LOOKBACK_HOURS=24
